# --- Frontend (build) ---
# Lista detallada: ver frontend/.env.example
VITE_API_URL=
VITE_IMPORT_API_KEY=
VITE_GOOGLE_CLIENT_ID=
# Legacy / no usado en el código actual del front:
GEMINI_API_KEY=
APP_URL=

# --- Backend / Railway ---
PORT=4000
NODE_ENV=production

# MySQL (obligatorio en producción)
# Railway: en el servicio WEB → Variables → "Add Variable Reference" → elegí el MySQL y enlazá
#   MYSQL_URL o DATABASE_URL (el plugin genera la URL). Sin eso el contenedor no arranca.
# Ej: mysql://usuario:pass@host:puerto/nombre_base
DATABASE_URL=

# O variables sueltas:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# SSL para MySQL remoto (muchas veces necesario en la nube)
MYSQL_SSL=true
# Por defecto el cliente NO verifica el certificado contra CAs públicas (evita error "self-signed certificate"
# con Railway y similares). Para exigir verificación estricta en producción avanzada:
# MYSQL_SSL_REJECT_UNAUTHORIZED=true

# Crear la base automáticamente al arrancar (CREATE DATABASE IF NOT EXISTS). Poné false si tu hosting ya la creó y el usuario no tiene permiso CREATE.
AUTO_CREATE_DATABASE=true

JWT_SECRET=

ADMIN_EMAIL=
ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=

HUB_API_KEY=

TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_USER_AGENT="LupoStore (tu-email@dominio.com)"
TIENDANUBE_API_VERSION=2025-03

IMPORT_API_KEY=
