# Copiá este archivo a .env en esta carpeta (frontend/) o definí las mismas variables
# en Vercel / Railway en la etapa de BUILD del frontend.
# Solo las que empiezan con VITE_ se incluyen en el bundle del navegador.

# --- API (obligatorio si el sitio y el backend están en dominios distintos) ---
# URL pública del backend, SIN barra al final. Incluí https:// (si solo ponés el dominio, el build
# también lo corrige, pero es mejor ser explícito). Ejemplo:
# VITE_API_URL=https://tu-app.up.railway.app
# Si el mismo servidor Express sirve /api y el front (un solo deploy), dejalo vacío.
VITE_API_URL=

# Misma clave que IMPORT_API_KEY en el backend (importación Tienda Nube desde /admin).
VITE_IMPORT_API_KEY=

# Client ID de Google Sign-In (mismo valor que GOOGLE_CLIENT_ID en el backend).
# Necesario cuando agregues el botón "Continuar con Google" en el front.
VITE_GOOGLE_CLIENT_ID=

# Opcional: desactivar HMR en entornos raros (por defecto no hace falta).
# DISABLE_HMR=true
