# --- Frontend (build) ---
VITE_API_URL=
VITE_IMPORT_API_KEY=
VITE_GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
APP_URL=

# --- Backend / Railway ---
PORT=4000
NODE_ENV=production

# MySQL: una sola URL (recomendado en Railway: copiá la variable que te da el plugin MySQL)
# Ej: mysql://usuario:pass@host:puerto/nombre_base
DATABASE_URL=

# O variables sueltas:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# SSL para MySQL remoto (muchas veces necesario en la nube)
MYSQL_SSL=true

# Crear la base automáticamente al arrancar (CREATE DATABASE IF NOT EXISTS). Poné false si tu hosting ya la creó y el usuario no tiene permiso CREATE.
AUTO_CREATE_DATABASE=true

JWT_SECRET=

ADMIN_EMAIL=
ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=

HUB_API_KEY=

TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_USER_AGENT="LupoStore (tu-email@dominio.com)"
TIENDANUBE_API_VERSION=2025-03

IMPORT_API_KEY=
