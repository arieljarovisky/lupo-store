# --- Frontend (build) ---
# Lista detallada: ver frontend/.env.example
# Misma URL pública del backend; incluí https:// (ej. https://xxx.up.railway.app). Build-time en Vite.
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=
# Legacy / no usado en el código actual del front:
GEMINI_API_KEY=
APP_URL=

# --- Backend / Railway ---
PORT=4000
NODE_ENV=production

# MySQL (obligatorio en producción)
# Railway: en el servicio WEB → Variables → "Add Variable Reference" → elegí el MySQL y enlazá
#   MYSQL_URL o DATABASE_URL (el plugin genera la URL). Sin eso el contenedor no arranca.
# Ej: mysql://usuario:pass@host:puerto/nombre_base
DATABASE_URL=

# O variables sueltas:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# SSL para MySQL remoto (muchas veces necesario en la nube)
MYSQL_SSL=true
# Por defecto el cliente NO verifica el certificado contra CAs públicas (evita error "self-signed certificate"
# con Railway y similares). Para exigir verificación estricta en producción avanzada:
# MYSQL_SSL_REJECT_UNAUTHORIZED=true

# Crear la base automáticamente al arrancar (CREATE DATABASE IF NOT EXISTS). Poné false si tu hosting ya la creó y el usuario no tiene permiso CREATE.
AUTO_CREATE_DATABASE=true

JWT_SECRET=

ADMIN_EMAIL=
ADMIN_PASSWORD=

GOOGLE_CLIENT_ID=877494194279-mefmhb285n9ll8v86a3vg0g27vg16s47.apps.googleusercontent.com

HUB_API_KEY=

TIENDANUBE_STORE_ID=
TIENDANUBE_ACCESS_TOKEN=
TIENDANUBE_USER_AGENT="LupoStore (tu-email@dominio.com)"
TIENDANUBE_API_VERSION=2025-03

# OAuth de Tienda Nube (recomendado para conectar la tienda desde /admin)
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=
# Debe apuntar al backend: https://tu-backend.up.railway.app/api/admin/tiendanube/oauth/callback
TIENDANUBE_REDIRECT_URI=
# Opcional: URL pública del frontend para volver a /admin luego de OAuth.
# Si no se define, vuelve al mismo host del backend.
ADMIN_DASHBOARD_URL=

# Checkout Mercado Pago
# Token secreto (backend): credenciales de tu app en developers.mercadopago.com
MERCADO_PAGO_ACCESS_TOKEN=
# URLs de retorno tras pagar en Checkout Pro (redirección a mercadopago.com).
# Deben ser HTTPS en producción y la misma base que tu sitio público (frontend).
# Si las dejás vacías, el backend usa FRONTEND_URL (abajo) para las tres.
# Ejemplo con sitio en Vercel:
# MERCADO_PAGO_SUCCESS_URL=https://tu-tienda.vercel.app/?mp=success
# MERCADO_PAGO_FAILURE_URL=https://tu-tienda.vercel.app/?mp=failure
# MERCADO_PAGO_PENDING_URL=https://tu-tienda.vercel.app/?mp=pending
MERCADO_PAGO_SUCCESS_URL=
MERCADO_PAGO_FAILURE_URL=
MERCADO_PAGO_PENDING_URL=
# URL pública del frontend (misma que uses en el navegador). Fallback para back_urls si no definís las de arriba.
FRONTEND_URL=
# Notificaciones por email (Resend)
RESEND_API_KEY=
# Remitente válido en Resend. Ej: Lupo Store <ventas@tudominio.com>
RESEND_FROM_EMAIL=
# Webhook a configurar en Mercado Pago:
# POST https://tu-backend.com/api/orders/webhooks/mercado-pago

# Webhooks privacidad Tienda Nube (configurar en el panel de la app):
# https://tu-backend.up.railway.app/api/tiendanube/privacy/store-redact
# https://tu-backend.up.railway.app/api/tiendanube/privacy/customers-redact
# https://tu-backend.up.railway.app/api/tiendanube/privacy/customers-data-request

# --- MiCorreo (Correo Argentino) — cotización oficial en checkout ---
# Si están definidos USER, PASSWORD, CUSTOMER_ID y CP de origen, el checkout usa POST /rates en lugar de la heurística local.
# QA: https://apitest.correoargentino.com.ar/micorreo/v1 | Prod: https://api.correoargentino.com.ar/micorreo/v1
MICORREO_API_BASE=
MICORREO_USER=
MICORREO_PASSWORD=
MICORREO_CUSTOMER_ID=
# CP desde donde despachás (mismo formato que en MiCorreo, ej. 1757 o B1842ZAB)
MICORREO_POSTAL_CODE_ORIGIN=
# Paquete por defecto para cotizar (enteros según doc MiCorreo)
MICORREO_PACKAGE_WEIGHT_G=1000
MICORREO_PACKAGE_HEIGHT_CM=10
MICORREO_PACKAGE_WIDTH_CM=20
MICORREO_PACKAGE_LENGTH_CM=30
